# 默认所有文本文件使用 LF 换行，由 Git 自动检测并标准化
* text=auto eol=lf

# Go 源码 / 模块文件 强制 LF
*.go         text eol=lf
go.mod       text eol=lf
go.sum       text eol=lf

# 文档 / 配置文件 LF
*.md         text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.toml       text eol=lf
.env*        text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Shell 脚本 强制 LF（Windows 上也要保持 LF，否则 bash 会报错）
*.sh         text eol=lf

# Windows 脚本 强制 CRLF
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# 数据 / 样本文件
*.csv        text eol=lf
*.example    text eol=lf

# 二进制文件 不做行尾转换 / 不参与 diff
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        text eol=lf
*.exe        binary
*.dll        binary
*.so         binary
*.dylib      binary
*.zip        binary
*.gz         binary
*.tar        binary
*.7z         binary

# GitHub 语言识别：忽略生成 / 第三方代码
vendor/**    linguist-vendored
*.pb.go      linguist-generated
